{
  "name": "@apps/bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "echo 'No tests yet for @apps/bot'",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "temp": "node scripts/temp-run.mjs"
  },
  "dependencies": {
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "tsx": "^4.19.2"
  }
}
