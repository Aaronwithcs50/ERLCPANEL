# =========================================================
# Environment Profile
# =========================================================
NODE_ENV=development
APP_ENV=development

# =========================================================
# Bot Service (apps/bot)
# =========================================================
BOT_TOKEN=
BOT_CLIENT_ID=
BOT_GUILD_ID=
BOT_LOG_LEVEL=info

# =========================================================
# API Service (apps/api)
# =========================================================
API_HOST=0.0.0.0
API_PORT=3001
API_CORS_ORIGIN=http://localhost:3000
API_JWT_SECRET=
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=100

# =========================================================
# Web Service (apps/web)
# =========================================================
WEB_HOST=0.0.0.0
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_APP_ENV=development

# =========================================================
# Database (packages/db)
# =========================================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/erlcpanel
SHADOW_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/erlcpanel_shadow
DB_SEED_ENABLED=true

# =========================================================
# Redis
# =========================================================
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=erlcpanel:

# =========================================================
# Logging / Observability
# =========================================================
LOG_LEVEL=info
LOG_PRETTY=true
LOG_SERVICE_NAME=erlcpanel
SENTRY_DSN=

# =========================================================
# Environment Presets (override in env-specific files)
# =========================================================
# .env.development
# NODE_ENV=development
# APP_ENV=development
#
# .env.staging
# NODE_ENV=production
# APP_ENV=staging
#
# .env.production
# NODE_ENV=production
# APP_ENV=production
