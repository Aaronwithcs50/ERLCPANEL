{
  "name": "erlcpanel",
  "version": "0.1.0",
  "private": true,
  "description": "Developer tooling scaffold for ERLCPANEL",
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "clients/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --check",
    "format:fix": "prettier . --write",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:gateway": "vitest run tests/mock-gateway",
    "test:contract": "vitest run tests/contract",
    "docs:api": "redoc-cli build docs/api/openapi.yaml --output docs/site/api/index.html",
    "docs:typedoc": "typedoc --entryPointStrategy expand --out docs/site/sdk src",
    "docs:build": "npm run docs:api && npm run docs:typedoc",
    "prepare": "husky",
    "dev:all": "pnpm -r --parallel run dev",
    "build:all": "pnpm -r run build",
    "test:all": "pnpm -r run test",
    "lint:all": "pnpm -r run lint",
    "format:all": "pnpm -r run format",
    "typecheck:all": "pnpm -r run typecheck",
    "bot:dev": "pnpm --filter @apps/bot run dev",
    "bot:temp": "pnpm --filter @apps/bot run temp"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,json,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@eslint/js": "^9.22.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.2",
    "@semantic-release/release-notes-generator": "^14.0.3",
    "@types/express": "^5.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.10",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "@vitest/coverage-v8": "^3.0.8",
    "ajv": "^8.17.1",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "husky": "^9.1.7",
    "js-yaml": "^4.1.0",
    "lint-staged": "^15.5.0",
    "prettier": "^3.5.3",
    "redoc-cli": "^0.13.21",
    "semantic-release": "^24.2.3",
    "supertest": "^7.0.0",
    "tsx": "^4.19.3",
    "typedoc": "^0.28.1",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.0.8"
  }
}
