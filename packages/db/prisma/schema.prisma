generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @map("_id") @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

enum ModerationActionType {
  WARN
  MUTE
  UNMUTE
  KICK
  BAN
  UNBAN
  NOTE
}

enum ModerationTargetType {
  MEMBER
  DISCORD_ACCOUNT
  ROBLOX_ACCOUNT
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  REVIEWING
  APPROVED
  REJECTED
  WITHDRAWN
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum LOAStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
}

enum ShiftEventType {
  START
  END
  BREAK_START
  BREAK_END
  CORRECTION
}

enum ActivityEventType {
  COMMAND
  MODERATION
  SHIFT
  APPLICATION
  SYSTEM
}

enum IncidentStatus {
  OPEN
  MONITORING
  RESOLVED
}

enum ServiceState {
  OPERATIONAL
  DEGRADED
  OUTAGE
}

model Guild {
  id        String   @id @map("_id")
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members              Member[]
  applications         Application[]
  joinRequests         JoinRequest[]
  loaRequests          LOARequest[]
  moderationActions    ModerationAction[]
  moderationStatistics ModerationStatistic[]
  shifts               Shift[]
  shiftEvents          ShiftEvent[]
  activityEvents       ActivityEvent[]
  leaderboardSnapshots LeaderboardSnapshot[]
  settings             GuildSettings?
  roleMappings         RoleMapping[]
  channelMappings      ChannelMapping[]
  featureFlags         FeatureFlag[]
  apiTokens            ApiToken[]
  webhookSubs          WebhookSubscription[]
  incidents            Incident[]
  serviceUptime        ServiceUptime[]
  accountLinks         AccountLink[]

  @@index([createdAt])
}

model Member {
  id            String    @id @map("_id") @default(cuid())
  guildId       String
  discordUserId String?
  robloxUserId  String?
  displayName   String?
  joinedAt      DateTime  @default(now())
  leftAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  guild             Guild              @relation(fields: [guildId], references: [id], onDelete: Cascade)
  discordAccount    DiscordAccount?    @relation(fields: [discordUserId], references: [discordUserId])
  robloxAccount     RobloxAccount?     @relation(fields: [robloxUserId], references: [robloxUserId])
  moderationActions ModerationAction[]
  shifts            Shift[]
  applications      Application[]
  joinRequests      JoinRequest[]
  loaRequests       LOARequest[]

  @@unique([guildId, discordUserId])
  @@unique([guildId, robloxUserId])
  @@index([guildId, joinedAt, id])
  @@index([guildId, leftAt])
}

model DiscordAccount {
  id            String   @id @map("_id") @default(cuid())
  discordUserId String   @unique
  username      String
  globalName    String?
  avatarUrl     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  members      Member[]
  accountLinks AccountLink[]

  @@index([username])
}

model RobloxAccount {
  id           String   @id @map("_id") @default(cuid())
  robloxUserId String   @unique
  username     String
  displayName  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  members      Member[]
  accountLinks AccountLink[]

  @@index([username])
}

model AccountLink {
  id               String    @id @map("_id") @default(cuid())
  guildId          String
  discordAccountId String
  robloxAccountId  String
  linkedByMemberId String?
  isPrimary        Boolean   @default(false)
  createdAt        DateTime  @default(now())
  unlinkedAt       DateTime?

  guild          Guild          @relation(fields: [guildId], references: [id], onDelete: Cascade)
  discordAccount DiscordAccount @relation(fields: [discordAccountId], references: [id], onDelete: Cascade)
  robloxAccount  RobloxAccount  @relation(fields: [robloxAccountId], references: [id], onDelete: Cascade)

  @@unique([guildId, discordAccountId, robloxAccountId])
  @@index([guildId, createdAt, id])
}

model ModerationAction {
  id            String               @id @map("_id") @default(cuid())
  guildId       String
  memberId      String?
  actionType    ModerationActionType
  targetType    ModerationTargetType
  targetId      String
  reason        String?
  performedById String?
  expiresAt     DateTime?
  createdAt     DateTime             @default(now())

  guild   Guild               @relation(fields: [guildId], references: [id], onDelete: Cascade)
  member  Member?             @relation(fields: [memberId], references: [id], onDelete: SetNull)
  history ModerationHistory[]

  @@index([guildId, createdAt, id])
  @@index([guildId, targetId, createdAt])
  @@index([guildId, actionType, createdAt])
}

model ModerationHistory {
  id                 String   @id @map("_id") @default(cuid())
  moderationActionId String
  previousReason     String?
  newReason          String?
  changedById        String?
  changedAt          DateTime @default(now())

  moderationAction ModerationAction @relation(fields: [moderationActionId], references: [id], onDelete: Cascade)

  @@index([moderationActionId, changedAt])
}

model ModerationStatistic {
  id          String               @id @map("_id") @default(cuid())
  guildId     String
  memberId    String
  actionType  ModerationActionType
  count       Int                  @default(0)
  periodStart DateTime
  periodEnd   DateTime
  updatedAt   DateTime             @updatedAt

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, memberId, actionType, periodStart, periodEnd])
  @@index([guildId, periodStart, periodEnd])
  @@index([guildId, actionType, count])
}

model Shift {
  id               String    @id @map("_id") @default(cuid())
  guildId          String
  memberId         String
  startedAt        DateTime
  endedAt          DateTime?
  totalDurationSec Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  guild  Guild        @relation(fields: [guildId], references: [id], onDelete: Cascade)
  member Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  breaks ShiftBreak[]
  events ShiftEvent[]

  @@index([guildId, startedAt, id])
  @@index([guildId, memberId, startedAt])
  @@index([guildId, endedAt])
}

model ShiftBreak {
  id          String    @id @map("_id") @default(cuid())
  shiftId     String
  startedAt   DateTime
  endedAt     DateTime?
  durationSec Int       @default(0)

  shift Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@index([shiftId, startedAt])
}

model ShiftEvent {
  id        String         @id @map("_id") @default(cuid())
  guildId   String
  shiftId   String
  eventType ShiftEventType
  metadata  Json?
  createdAt DateTime       @default(now())

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)
  shift Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@index([guildId, createdAt, id])
  @@index([guildId, shiftId, createdAt])
  @@index([guildId, eventType, createdAt])
}

model ActivityEvent {
  id        String            @id @map("_id") @default(cuid())
  guildId   String
  memberId  String?
  eventType ActivityEventType
  source    String
  payload   Json?
  createdAt DateTime          @default(now())

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId, createdAt, id])
  @@index([guildId, memberId, createdAt, id])
  @@index([guildId, eventType, createdAt])
}

model LeaderboardSnapshot {
  id          String   @id @map("_id") @default(cuid())
  guildId     String
  metric      String
  memberId    String
  value       Float
  rank        Int
  periodStart DateTime
  periodEnd   DateTime
  capturedAt  DateTime @default(now())

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId, metric, periodStart, periodEnd, rank])
  @@index([guildId, metric, value(sort: Desc)])
  @@index([guildId, capturedAt])
}

model Application {
  id          String            @id @map("_id") @default(cuid())
  guildId     String
  memberId    String
  formKey     String
  status      ApplicationStatus @default(DRAFT)
  submittedAt DateTime?
  reviewedAt  DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  guild     Guild                 @relation(fields: [guildId], references: [id], onDelete: Cascade)
  member    Member                @relation(fields: [memberId], references: [id], onDelete: Cascade)
  responses ApplicationResponse[]

  @@index([guildId, status, createdAt, id])
  @@index([guildId, memberId, createdAt])
}

model ApplicationResponse {
  id            String   @id @map("_id") @default(cuid())
  applicationId String
  questionKey   String
  answer        String
  createdAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, questionKey])
  @@index([applicationId, createdAt])
}

model JoinRequest {
  id          String            @id @map("_id") @default(cuid())
  guildId     String
  memberId    String
  status      JoinRequestStatus @default(PENDING)
  message     String?
  requestedAt DateTime          @default(now())
  resolvedAt  DateTime?

  guild  Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([guildId, status, requestedAt, id])
}

model LOARequest {
  id          String    @id @map("_id") @default(cuid())
  guildId     String
  memberId    String
  status      LOAStatus @default(PENDING)
  reason      String?
  startDate   DateTime
  endDate     DateTime
  requestedAt DateTime  @default(now())
  resolvedAt  DateTime?

  guild  Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)
  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([guildId, status, requestedAt, id])
  @@index([guildId, startDate, endDate])
}

model GuildSettings {
  guildId                 String   @id @map("_id")
  locale                  String   @default("en-US")
  timezone                String   @default("UTC")
  activityRetentionDays   Int      @default(90)
  shiftEventRetentionDays Int      @default(180)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)
}

model RoleMapping {
  id        String   @id @map("_id") @default(cuid())
  guildId   String
  key       String
  roleId    String
  createdAt DateTime @default(now())

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, key])
  @@index([guildId, roleId])
}

model ChannelMapping {
  id        String   @id @map("_id") @default(cuid())
  guildId   String
  key       String
  channelId String
  createdAt DateTime @default(now())

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, key])
  @@index([guildId, channelId])
}

model FeatureFlag {
  id        String   @id @map("_id") @default(cuid())
  guildId   String
  key       String
  enabled   Boolean  @default(false)
  rollout   Int      @default(100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, key])
  @@index([guildId, enabled])
}

model ApiToken {
  id         String    @id @map("_id") @default(cuid())
  guildId    String
  name       String
  tokenHash  String    @unique
  scopes     String[]
  lastUsedAt DateTime?
  expiresAt  DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId, createdAt])
  @@index([guildId, revokedAt])
}

model WebhookSubscription {
  id              String    @id @map("_id") @default(cuid())
  guildId         String
  event           String
  endpoint        String
  secretHash      String
  isActive        Boolean   @default(true)
  lastDeliveredAt DateTime?
  createdAt       DateTime  @default(now())

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId, event, isActive])
}

model Incident {
  id          String         @id @map("_id") @default(cuid())
  guildId     String
  title       String
  description String?
  status      IncidentStatus @default(OPEN)
  startedAt   DateTime       @default(now())
  resolvedAt  DateTime?
  createdAt   DateTime       @default(now())

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId, status, startedAt])
}

model ServiceUptime {
  id         String       @id @map("_id") @default(cuid())
  guildId    String
  serviceKey String
  state      ServiceState
  observedAt DateTime     @default(now())
  responseMs Int?
  errorCode  String?

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId, serviceKey, observedAt])
  @@index([guildId, state, observedAt])
}
